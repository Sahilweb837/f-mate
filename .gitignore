# Monorepo .gitignore

# Dependencies
node_modules/
vendor/
**/node_modules/
**/vendor/

# Laravel
backend/storage/*.key
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/testing/*
backend/storage/framework/views/*
backend/storage/logs/*
backend/.env
backend/.phpunit.result.cache
backend/public/storage
backend/public/hot

# Next.js
frontend/.next/
frontend/out/
frontend/build/
frontend/.env*
frontend/next-env.d.ts
frontend/*.tsbuildinfo

# Misc
.DS_Store
Thumbs.db
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel
